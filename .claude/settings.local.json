{
  "permissions": {
    "allow": [
      "Bash(npx ecc-agentshield *)",
      "Bash(npx mkcert *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "PowerShell(Remove-Item -Recurse -Force *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️ 위험한 도구가 실행되려고 합니다. 잠깐!'"
          }
        ]
      }
    ]
  }
}
